// Musa – Prisma Schema
// Desarrollo: provider = "sqlite", DATABASE_URL = "file:./dev.db"
// Producción:  provider = "postgresql", DATABASE_URL = <postgres_url>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// BUSINESS (Negocio/Salón)
// ─────────────────────────────────────────────
model Business {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  category             String?  // "nails"|"hair"|"brows"|"makeup"|"other"
  phone                String?
  city                 String?
  address              String?
  
  planId               String
  plan                 Plan     @relation(fields: [planId], references: [id])
  
  // Tracking de uso para límites
  currentMonthBookings Int      @default(0)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users                User[]
  invitations          Invitation[]
}

// ─────────────────────────────────────────────
// PLAN (Definición de planes y límites)
// ─────────────────────────────────────────────
model Plan {
  id          String   @id @default(cuid())
  name        String   @unique // "FREE"|"PRO"
  price       Float
  currency    String   @default("USD")
  limits      Json     // { "maxStaff": 1, "maxMonthlyAppointments": 30, "features": ["stats"] }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businesses  Business[]
}

// ─────────────────────────────────────────────
// USER (Profesional/Dueño/Staff)
// ─────────────────────────────────────────────
model User {
  id               String   @id @default(cuid())
  phone            String   @unique          // identificador principal (+58...)
  email            String?  @unique
  name             String
  passwordHash     String
  slug             String   @unique          // URL pública: /b/[businessSlug]/[staffSlug]
  role             String   @default("OWNER") // "OWNER"|"STAFF"
  
  businessId       String?
  business         Business? @relation(fields: [businessId], references: [id])
  
  serviceType      String?                   // "nails"|"hair"|"brows"|"makeup"|"other"
  bio              String?
  avatarUrl        String?
  whatsapp         String?
  instagram        String?
  onboardingDone   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  services         Service[]
  clients          Client[]
  appointments     Appointment[]
  settings         ProfessionalSettings?
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
}

// ─────────────────────────────────────────────
// INVITATION (Para unir staff al negocio)
// ─────────────────────────────────────────────
model Invitation {
  id         String    @id @default(cuid())
  businessId String
  token      String    @unique
  code       String    @unique
  role       String    @default("STAFF")
  expiresAt  DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// CLIENT (Clienta del negocio)
// ─────────────────────────────────────────────
model Client {
  id         String   @id @default(cuid())
  businessId String?                          // Ahora pertenece al negocio
  userId     String?                          // Opcional: profesional preferida/asignada
  name       String
  phone      String
  email      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  appointments Appointment[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]

  @@unique([userId, phone])
}

// ─────────────────────────────────────────────
// SERVICE (Menú de servicios)
// ─────────────────────────────────────────────
model Service {
  id          String   @id @default(cuid())
  userId      String?                          // Opcional si es global del negocio
  businessId  String?
  name        String
  description String?
  category    String                         // "nails"|"hair"|"brows"|"makeup"|"other"
  durationMin Int                            // Duración en minutos
  price       Float
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

// ─────────────────────────────────────────────
// APPOINTMENT (Cita)
// ─────────────────────────────────────────────
model Appointment {
  id        String   @id @default(cuid())
  userId    String                           // Staff asignado
  clientId  String
  serviceId String
  startTime DateTime
  endTime   DateTime
  // "pending"|"confirmed"|"completed"|"no_show"|"cancelled"
  status    String   @default("confirmed")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  payment Payment?
  notifications Notification[]
}

// ─────────────────────────────────────────────
// NOTIFICATION (Internas de la app)
// ─────────────────────────────────────────────
model Notification {
  id            String   @id @default(cuid())
  userId        String?  // Destinatario (Staff/Owner)
  clientId      String?  // Destinatario (Cliente)
  appointmentId String?
  type          String?  // "new_booking"|"cancelled"|"reminder"
  title         String
  body          String
  url           String?
  data          Json?    // Información extra
  read          Boolean  @default(false)
  readAt        DateTime?
  createdAt     DateTime @default(now())

  user        User?        @relation(fields: [userId], references: [id])
  client      Client?      @relation(fields: [clientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

// ─────────────────────────────────────────────
// PUSH SUBSCRIPTION (Web Push)
// ─────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  clientId  String?
  endpoint  String   @unique
  keys      Json     // { "p256dh": "...", "auth": "..." }
  userAgent String?
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

// ─────────────────────────────────────────────
// PAYMENT (Pago registrado para una cita)
// ─────────────────────────────────────────────
model Payment {
  id            String    @id @default(cuid())
  appointmentId String    @unique
  amount        Float
  currency      String    @default("USD")
  // "efectivo_bs"|"efectivo_usd"|"pago_movil"|"zelle"|"otro"
  method        String    @default("efectivo_usd")
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PROFESSIONAL SETTINGS (Horarios por Staff)
// ─────────────────────────────────────────────
model ProfessionalSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  // JSON array: [1,2,3,4,5] = Lun–Vie (0=Dom, 6=Sáb)
  workDays       String   @default("[1,2,3,4,5]")
  startHour      Int      @default(9)        // 9 = 09:00
  endHour        Int      @default(18)       // 18 = 18:00
  slotDuration   Int      @default(30)       // Minutos por slot
  currency       String   @default("USD")
  bookingEnabled Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


